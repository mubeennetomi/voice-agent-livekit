# LiveKit credentials — find these in your LiveKit Cloud project settings:
# https://cloud.livekit.io  ->  Settings  ->  Keys
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Your LiveKit server URL (the wss:// one, e.g. wss://my-project-abc123.livekit.cloud)
LIVEKIT_URL=wss://your-project.livekit.cloud

# The agent_name you set when registering your agent worker (WorkerOptions(agent_name="...")).
# This is required for EXPLICIT dispatch — the token tells LiveKit which agent to dispatch.
LIVEKIT_AGENT_NAME=your-agent-name

# Shared secret your agent uses to POST metrics to /api/metrics.
# Set the same value in your agent's environment.
METRICS_INGEST_TOKEN=a-long-random-string
